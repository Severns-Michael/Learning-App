# Copy this file to .env and fill in real values. Never commit .env.

# ----- Anthropic API -----
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model to use for ingestion / item generation.
# Recommended: claude-sonnet-4-6 for dev/iteration, claude-opus-4-7 for final runs.
CLAUDE_MODEL=claude-sonnet-4-6

# ----- Django -----
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-key
DJANGO_DEBUG=True

# ----- Postgres (matches docker-compose.yml) -----
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
